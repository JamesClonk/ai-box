#!/bin/bash

# moe qwen3.6 with 262144 context size and metrics endpoint enabled, for chatting
llama-server --ctx-size 262144 --metrics -hf unsloth/Qwen3.6-35B-A3B-GGUF:UD-Q4_K_M

# dense qwen3.6 optimal for coding on m4 macbook
llama-server --ctx-size 65536 -hf unsloth/Qwen3.6-27B-GGUF:Q4_K_M \
	--no-mmproj \
	--fit on \
	-np 1 \
	--cache-ram 4096 -ctxcp 2 \
	--jinja \
	--temp 0.6 \
	--top-p 0.95 \
	--top-k 20 \
	--min-p 0.0 \
	--presence-penalty 0.0 \
	--repeat-penalty 1.0 \
	--reasoning on \
	--chat-template-kwargs '{"preserve_thinking": true}'
