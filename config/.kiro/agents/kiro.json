{
  "name": "kiro",
  "description": "Customized kiro agent that cannot read .git metadata",
  "resources": [
    "file://.kiro/steering/**/*.md",
    "skill://~/.kiro/skills/**/SKILL.md"
  ],
  "tools": ["*"],
  "allowedTools": ["*"],
  "toolsSettings": {
    "shell": {
      "deniedCommands": ["git.*", ".*\\bgit\\b.*"]
    },
    "read": {
      "deniedPaths": [
        "~/.config/**",
        "~/.local/**",
        "**/.git/**",
        "**/vendor/**"
      ]
    },
    "write": {
      "deniedPaths": [
        "~/.config/**",
        "~/.local/**",
        "**/.git/**",
        "**/vendor/**"
      ]
    }
  }
}
